{
  "name": "agi-farm",
  "version": "3.3.1",
  "description": "Multi-agent AI team builder for OpenClaw — bootstrap complete teams with Paperclip dashboard, auto-dispatcher, and infrastructure",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "agi-farm": "scripts/agi-farm.js"
  },
  "license": "MIT",
  "author": "oabdelmaksoud",
  "homepage": "https://github.com/oabdelmaksoud/AGI-FARM-PLUGIN",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oabdelmaksoud/AGI-FARM-PLUGIN.git"
  },
  "bugs": {
    "url": "https://github.com/oabdelmaksoud/AGI-FARM-PLUGIN/issues"
  },
  "files": [
    "dist",
    "paperclip",
    "openclaw.plugin.json",
    "server",
    "scripts",
    "templates",
    "skills",
    "ecc-resources",
    "hooks",
    "README.md",
    "LICENSE.md"
  ],
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "scripts": {
    "postinstall": "node scripts/validate-config.js",
    "setup:paperclip": "cd paperclip && pnpm install",
    "prebuild": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:install": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand tests/install-*.test.js",
    "test:install:real-openclaw": "bash scripts/test-install-smoke.sh",
    "start-dashboard": "node scripts/paperclip.js",
    "validate": "node scripts/validate-config.js",
    "lint": "eslint src --ext .ts,.js",
    "setup": "node scripts/setup.js"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw-extension",
    "multi-agent",
    "agent-orchestration",
    "agent-team",
    "agentic-workflow",
    "team-management",
    "auto-dispatcher",
    "paperclip",
    "dashboard",
    "cli-wizard",
    "agi",
    "collaborative-ai"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "inquirer": "^12.4.1",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/ejs": "^3.1.5",
    "@types/inquirer": "^9.0.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.4",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.24.1"
  }
}
